{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DictateMe",
  "version": "0.1.0",
  "identifier": "org.dictateme.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "DictateMe",
        "url": "index.html",
        "width": 440,
        "height": 340,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "main",
        "title": "DictateMe",
        "url": "settings.html",
        "width": 680,
        "height": 600,
        "visible": true,
        "resizable": true,
        "minWidth": 560,
        "minHeight": 480,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon-idle.png",
      "iconAsTemplate": true,
      "tooltip": "DictateMe"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
